# Copy this to `.env` (which must stay out of git) and fill in real values.
# Used by profiles.yml via env_var() and by the dagster sensors/resources.

# --- Snowflake (used by dbt profiles.yml) ---
SNOWFLAKE_ACCOUNT=uodavys-yv39599
SNOWFLAKE_USER=ifistic
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=accountadmin
SNOWFLAKE_DATABASE=ifiok_db
SNOWFLAKE_WAREHOUSE=compute_wh
SNOWFLAKE_SCHEMA=RAW

# --- dbt ---
DBT_PROFILES_DIR=../my_dbt_project

# --- Dagster / alerting ---
SLACK_BOT_TOKEN=

# --- Only needed if using dagster.yaml.postgres-example ---
DAGSTER_PG_USERNAME=
DAGSTER_PG_PASSWORD=
DAGSTER_PG_HOST=localhost
DAGSTER_PG_DB=dagster
DAGSTER_PG_PORT=5432
